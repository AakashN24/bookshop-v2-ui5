<mvc:View controllerName="bookshopcatalogv2.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <Table id="Books" items="{ path: '/Books'}">
            <headerToolbar>
                <Toolbar id='toolbar'>
                    <Title id='booksTable' text='{i18n>bookTableTitle}'/>
                    <ToolbarSpacer id='toolbarSpacer' />
                    <Button id='createBtn' text='{i18n>createBtnTitle}' press='.onCreate'/>
                </Toolbar>
            </headerToolbar>
            <columns>
                <Column id='column1'>
                    <Text id='textcolumn1text' text='{i18n>columnText1}'/>
                </Column>
                <Column id='column2'>
                    <Text id='textcolumn2text' text='{i18n>columnText2}'/>
                </Column>
                <Column id='column3'>
                    <Text id='textcolumn3text' text='{i18n>columnText3}' />
                </Column>
                <Column id="actionColumn"></Column>
            </columns>
            <ColumnListItem id="columnlistItem1">
                <ObjectIdentifier id='ObjectIdentifier1' text="{ID}" />
                <!-- <ObjectIdentifier id='ObjectIdentifier2' text="{title}"/> -->
                <Text id='column2text' text="{title}" />
                <ObjectIdentifier id='ObjectIdentifier3' text="{stock}" />
                <FlexBox id='Hbox'>
                    <Button id='delete' icon="sap-icon://delete" press="onDeletePress"/>
                    <Button id='edit' icon="sap-icon://edit" press="onEditPress"/>
                </FlexBox>
            </ColumnListItem>
        </Table>
    </Page>
</mvc:View>
