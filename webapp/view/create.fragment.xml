<core:FragmentDefinition id="fragment1"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog id="dialog1" title="New Book" afterClose="onAfterCloseDialog">
        <!-- <VBox id='vBox1'> -->
        <f:SimpleForm id="form">
            <Label id="idText" text='ID' labelFor="idInput"/>
            <Input id='idInput' width="100%" required="true" type="Number" value="{dialogInput>/ID}" />
            <Label id='text1' text='Book Name' labelFor="input1" />
            <Input id='input1' width="100%" required="true" value="{dialogInput>/title}"/>
            <Label id='StockLabel' text='Stock' labelFor="stockInput" />
            <Input id='stockInput' required="true" type="Number" value="{dialogInput>/stock}"/>
        </f:SimpleForm>
        <beginButton>
            <Button id="create" press="onDialogCreate" text='Add'/>
        </beginButton>
        <endButton>
            <Button id='cancel' press='onDialogCancel' text='Cancel'/>
        </endButton>
        <!-- </VBox> -->
    </Dialog>
</core:FragmentDefinition>
